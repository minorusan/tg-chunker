  "messages": [
    { "id": 1, "type": "message", "date": "2019-05-01T10:00:00", "from": "Олег", "from_id": "user1", "text": "Старе правило: пенсіонерам знижка 5% на гігієну. Поки лишаємо." },
    { "id": 2, "type": "message", "date": "2024-02-01T09:00:00", "from": "Олег", "from_id": "user1", "text": "Народ, оновлюю правило по гігієні." },
    { "id": 3, "type": "message", "date": "2024-02-01T09:01:00", "from": "Олег", "from_id": "user1", "text": "Гігієна поточна коштує 2300 грн." },
    { "id": 4, "type": "message", "date": "2024-02-01T09:02:00", "from": "Олег", "from_id": "user1", "text": "1800 вона коштує тіко коли пацієнт на брекетах і тіко коли порошком пройшлися. Уточнюйте у лікаря." },
    { "id": 5, "type": "message", "date": "2024-02-01T09:05:00", "from": "Марина", "from_id": "user2", "text": "Прийнято 👍" },
    { "id": 6, "type": "message", "date": "2024-02-03T12:00:00", "from": "Марина", "from_id": "user2", "text": "Ситуація по Світлані Головко. Дуже показова." },
    { "id": 7, "type": "message", "date": "2024-02-03T12:01:00", "from": "Марина", "from_id": "user2", "text": "Була онлайн-консультація на пів години, затягнулась на годину." },
    { "id": 8, "type": "message", "date": "2024-02-03T12:02:00", "from": "Марина", "from_id": "user2", "text": "Я написала що з Світлани 1000грн. Обурення, відмова платити." },
    { "id": 9, "type": "message", "date": "2024-02-03T12:03:00", "from": "Марина", "from_id": "user2", "text": "Провела 1000грн як списання. Свєту онлайн надовго більше не беремо." },
    { "id": 10, "type": "message", "date": "2024-02-10T15:00:00", "from": "Олег", "from_id": "user1", "text": "Важливий нюанс по імплантах." },
    { "id": 11, "type": "message", "date": "2024-02-10T15:01:00", "from": "Олег", "from_id": "user1", "text": "Коли пацієнт з імплантом — в технічку входить ще вартість платформи." },
    { "id": 12, "type": "message", "date": "2024-02-10T15:02:00", "from": "Олег", "from_id": "user1", "text": "Її важко врахувати. Якщо придумаєте як — пишіть сюди." },
    { "id": 13, "type": "message", "date": "2024-02-11T10:00:00", "from": "Марина", "from_id": "user2", "text": "А по Петру Ковалю що робимо?" },
    { "id": 14, "type": "message", "date": "2024-02-11T10:01:00", "from": "Марина", "from_id": "user2", "text": "У нього імплант та коронка. Інше не чіпаємо?" },
    { "id": 15, "type": "message", "date": "2024-02-11T10:05:00", "from": "Олег", "from_id": "user1", "text": "Тільки відсутній зуб — імплант та коронка. Усе інше діло десяте." },
    { "id": 16, "type": "message", "date": "2024-02-12T11:00:00", "from": "Олег", "from_id": "user1", "text": "І політика по телефонним консультаціям." },
    { "id": 17, "type": "message", "date": "2024-02-12T11:01:00", "from": "Олег", "from_id": "user1", "text": "Все що 'по телефону' — я не маю можливості оцінити якість." },
    { "id": 18, "type": "message", "date": "2024-02-12T11:02:00", "from": "Олег", "from_id": "user1", "text": "Відповідно не зараховую такі консультації проти адміністратора." },
    { "id": 19, "type": "message", "date": "2024-02-12T11:10:00", "from": "Марина", "from_id": "user2", "text": "Зрозуміло." }
  ]
}
