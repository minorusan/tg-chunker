{
  "name": "tg-chunker",
  "version": "1.0.0",
  "description": "Generalist Telegram-chat anonymiser + RAG proposition-chunker, powered entirely by a local LLM (Ollama). Prepares a privacy-safe knowledge base for a RAG agent.",
  "type": "module",
  "bin": { "tg-chunker": "src/index.ts" },
  "scripts": {
    "start": "node src/index.ts --sourceDir ./data/raw --ollamaIp 127.0.0.1:11434 --groupingTags employee,patient --domain clinic_admin",
    "build-index": "node scripts/build-index.ts",
    "retrieve": "node scripts/retrieve.ts",
    "examples": "node scripts/run-examples.ts"
  },
  "engines": { "node": ">=22.6" },
  "license": "MIT"
}
