  "messages": [
    { "id": 1, "type": "message", "date": "2024-06-01T08:30:00", "from": "Ірина", "from_id": "user3", "text": "Нагадування на сьогодні." },
    { "id": 2, "type": "message", "date": "2024-06-01T08:31:00", "from": "Ірина", "from_id": "user3", "text": "Оксана Федій — нагадати про гігієну, записана на 24 вересня." },
    { "id": 3, "type": "message", "date": "2024-06-01T08:32:00", "from": "Ірина", "from_id": "user3", "text": "Світлана Головко — досі не оплатила акт за 03.06, грошей нема." },
    { "id": 4, "type": "message", "date": "2024-06-01T08:40:00", "from": "Марина", "from_id": "user2", "text": "По Світлані я в курсі, вона проблемна. Передзвони Свєті ще раз сьогодні." },
    { "id": 5, "type": "message", "date": "2024-06-01T08:41:00", "from": "Ірина", "from_id": "user3", "text": "Ок, передзвоню." },
    { "id": 6, "type": "message", "date": "2024-06-02T09:00:00", "from": "Марина", "from_id": "user2", "text": "Оксана Федій видаляла всі зуби, буде повна імплантація." },
    { "id": 7, "type": "message", "date": "2024-06-02T09:01:00", "from": "Марина", "from_id": "user2", "text": "По Оксані — не забудь додати рахунок на платформу, як казав Олег." },
    { "id": 8, "type": "message", "date": "2024-06-02T09:10:00", "from": "Ірина", "from_id": "user3", "text": "Записала. По Федій все занесла в картку." }
  ]
}
